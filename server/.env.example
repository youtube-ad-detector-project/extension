# Groq Whisper API 키 — https://console.groq.com 에서 발급
# 이 파일을 .env.local 로 복사한 뒤 키를 채운다 (Next.js 가 자동 로드)
GROQ_API_KEY=

# HuggingFace Inference 토큰 — https://huggingface.co/settings/tokens 에서 발급
# 룰 엔진이 위반·의심으로 거른 문장을 파인튜닝 분류 모델로 2차 검증하는 /api/classify 에서 사용
HF_TOKEN=

# HF Inference Providers 라우터 설정 — provider 가 이 모델을 지원할 때만 동작
HF_CLASSIFY_MODEL=wldn/korean-text-classification-model
HF_CLASSIFY_PROVIDER=hf-inference

# provider 가 모델을 지원하지 않으면 Hugging Face Inference Endpoint 를 만든 뒤 그 URL 을 넣는다
HF_CLASSIFY_URL=
